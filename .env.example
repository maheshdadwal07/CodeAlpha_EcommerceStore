# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ecommerce_store
# For MongoDB Atlas (cloud): mongodb+srv://[USERNAME]:[PASSWORD]@[CLUSTER].mongodb.net/ecommerce_store

# JWT Secret (Generate a strong random string for production)
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Session Secret (Generate a strong random string for production)
SESSION_SECRET=your_super_secret_session_key_here_change_in_production

# Email Configuration (Optional - for order notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Payment Gateway (Optional - for future implementation)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# File Upload Configuration
MAX_FILE_SIZE=5242880
# 5MB = 5 * 1024 * 1024 bytes